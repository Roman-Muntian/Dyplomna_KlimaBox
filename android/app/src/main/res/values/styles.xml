<?xml version="1.0" encoding="utf-8"?>
<!--
  android/app/src/main/res/values/styles.xml

  LaunchTheme  — показується до першого Flutter-кадру (splash)
  NormalTheme  — активується після ініціалізації Flutter
-->
<resources>

    <!-- Тема splash екрана: прозорі статус/навігація-бар (edge-to-edge) -->
    <style name="LaunchTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
        <item name="android:windowTranslucentStatus">true</item>
        <item name="android:windowTranslucentNavigation">true</item>
    </style>

    <!-- Основна тема після запуску Flutter -->
    <style name="NormalTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowBackground">@color/splash_background</item>
    </style>

</resources>